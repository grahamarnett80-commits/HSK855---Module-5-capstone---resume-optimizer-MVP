# Public site URL (for SEO: canonical, sitemap, Open Graph). e.g. https://www.yourdomain.com
NEXT_PUBLIC_APP_URL=

# DB (Supabase: use Session mode / pooler URI from Project Settings → Database, not the direct URI)
DATABASE_URL=
# Access Supabase Studio here: http://127.0.0.1:54323/project/default

# Supabase Storage (for resume file uploads)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login # do not change
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup # do not change

# Google Gemini (resume scoring, suggestions, chat)
GEMINI_API_KEY=

# Stripe (optional for MVP)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_YEARLY=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_MONTHLY=
# One-time project packs (create Prices in Stripe Dashboard, CAD)
STRIPE_PRICE_ID_3_PACK=
STRIPE_PRICE_ID_10_PACK=
STRIPE_PRICE_ID_25_PACK=